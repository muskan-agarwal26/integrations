interval: {{interval}}
resource.tracer:
  enabled: {{enable_request_tracer}}
  filename: "../../logs/cel/http-request-trace-*.ndjson"
  maxbackups: 5
{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}
{{#if ssl}}
resource.ssl: {{ssl}}
{{/if}}
{{#if http_client_timeout}}
resource.timeout: {{http_client_timeout}}
{{/if}}
resource.url: {{url}}
state:
  api_key: {{api_key}}
  initial_interval: {{initial_interval}}
  batch_size: {{batch_size}}
  page: 1
redact:
  fields:
    - api_key
program: |-
  (
    state.?want_more.orValue(false) ?
      state
    :
      state.with({
        "start_time": state.?cursor.last_timestamp.orValue(now - duration(state.initial_interval)),
        "end_time": now,
      })
  ).as(state, state.with(
    request(
      "GET",
      state.url.trim_right("/") + "/audit?" +
        "page=" + string(state.?page.orValue(1)) +
        "&page_size=" + string(state.batch_size) +
        "&start_date=" + string(state.start_time) + "&end_date=" + string(state.end_time) +
        "&sort_order=desc"
    ).with({
      "Header": {
        "Authorization": ["Bearer " + string(state.api_key)]
      }
    }).do_request().as(resp, resp.StatusCode == 200 ?
      resp.Body.decode_json().as(body, {
        "events": (
          has(body.audit_logs) ?
            body.audit_logs.map(e, {
              "message": e.encode_json()
            })
          :
            []
        ),
        "cursor": {
          ?"last_timestamp": (has(body.audit_logs) && size(body.audit_logs) > 0) ?
            (has(state.?cursor.last_timestamp) ?
              optional.of(
                max(
                  state.cursor.last_timestamp,
                  body.audit_logs[0].updated_at
                )
              )
            :
              optional.of(body.audit_logs[0].updated_at)
            )
          :
            state.?cursor.last_timestamp
          },
          "want_more": int(state.?page.orValue(1)) < int(body.total_pages),
          "page": int(state.?page.orValue(1)) < int(body.total_pages) ?
            int(state.?page.orValue(1)) + 1
          :
            1,
        })
      :
        {
          "events":{
            "error": {
              "code": string(resp.StatusCode),
              "id": resp.Status,
              "message": "GET:" + state.url.trim_right("/") + "/audit: " + (
                size(resp.Body) != 0 ?
                  string(resp.Body)
                :
                  resp.Status + ' (' + string(resp.StatusCode) + ')'
              ),
            },
          },
          "want_more": false,
        }
      )
    ))
tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
{{#if processors}}
processors:
{{processors}}
{{/if}}
