config_version: "2"
interval: {{interval}}
request.method: "POST"
{{#if enable_request_tracer}}
request.tracer.filename: "../../logs/httpjson/http-request-trace-*.ndjson"
request.tracer.maxbackups: 5
{{/if}}
{{#if url}}
request.url: {{url}}/attributes/restSearch
{{/if}}
{{#if ssl}}
request.ssl: {{ssl}}
{{/if}}
{{#if http_client_timeout}}
request.timeout: {{http_client_timeout}}
{{/if}}
{{#if enable_rate_limit_headers}}
request.rate_limit.limit: '[[ .last_response.header.Get "X-Rate-Limit-Limit" ]]'
request.rate_limit.remaining: '[[ .last_response.header.Get "X-Rate-Limit-Remaining" ]]'
request.rate_limit.reset: '[[ add (toInt (.last_response.header.Get "X-Rate-Limit-Reset")) ((now).Unix) ]]'
{{/if}}
{{#if proxy_url}}
request.proxy_url: {{proxy_url}}
{{/if}}
request.body:
{{#if filters}}
  {{filters}}
{{/if}}
request.transforms:
{{#if api_token}}
- set:
    target: header.Authorization
    value: {{api_token}}
{{/if}}
- set:
    target: body.page
    value: 1
{{#if limit}}
- set:
    target: body.limit
    value: {{limit}}
{{/if}}
{{#if enforce_warning_list}}
- set:
    target: body.enforceWarninglist
    value: 1
{{/if}}
- set:
    target: body.returnFormat
    value: json
{{#if daily_refetch}}
# Daily refetch mode: every 24 hours, reset the request window to initial_interval to re-fetch all
# attributes (picking up current decay scores). The decision is made here in the request transform,
# where the cursor state is readable. The chosen refetch marker is echoed through url.params so the
# cursor value template can persist it: httpjson evaluates cursor templates with an empty .cursor, so
# the cursor field cannot read its own previous value, but it can read .last_response.url.params.
- set:
    target: body.timestamp
    value: |-
      [[- $dailyRefetchDuration := (parseDuration "24h") -]]
      [[- $initialInterval := (parseDuration "-{{initial_interval}}") -]]
      [[- $initialTimestamp := (now $initialInterval).Unix -]]
      [[- $isDailyRefetch := true -]]
      [[- if index .cursor "last_daily_refetch" -]]
        [[- $lastRefetch := (parseDate .cursor.last_daily_refetch "RFC3339") -]]
        [[- $nextRefetch := 0 -]]
        [[- with $lastRefetch -]]
          [[- $nextRefetch = .Add $dailyRefetchDuration -]]
        [[- end -]]
        [[- with $nextRefetch -]]
          [[- if .Before now -]]
            [[- $isDailyRefetch = true -]]
          [[- else -]]
            [[- $isDailyRefetch = false -]]
          [[- end -]]
        [[- end -]]
      [[- end -]]
      [[- if $isDailyRefetch -]]
        [[- $initialTimestamp -]]
      [[- else if index .cursor "timestamp" -]]
        [[- .cursor.timestamp -]]
      [[- else -]]
        [[- $initialTimestamp -]]
      [[- end -]]
    default: '[[ (now (parseDuration "-{{initial_interval}}")).Unix ]]'
- set:
    # Echo the refetch marker through url.params so the cursor value template can persist it: httpjson
    # evaluates cursor templates with an empty .cursor, so a cursor field cannot read its own previous
    # value, but it can read .last_response.url.params. When this poll performs a refetch (or it is the
    # first poll), the marker advances to now; otherwise the existing marker is carried forward.
    #
    # This param is sent to MISP on the wire, but MISP restSearch reads its filters from the POST JSON
    # body (and CakePHP-style /key:value/ path params), not from the ?query=string, so this extra query
    # parameter is ignored by the server. This mirrors the existing url.params.timestamp workaround.
    target: url.params.daily_refetch_at
    value: |-
      [[- $dailyRefetchDuration := (parseDuration "24h") -]]
      [[- $isDailyRefetch := true -]]
      [[- if index .cursor "last_daily_refetch" -]]
        [[- $lastRefetch := (parseDate .cursor.last_daily_refetch "RFC3339") -]]
        [[- $nextRefetch := 0 -]]
        [[- with $lastRefetch -]]
          [[- $nextRefetch = .Add $dailyRefetchDuration -]]
        [[- end -]]
        [[- with $nextRefetch -]]
          [[- if .Before now -]]
            [[- $isDailyRefetch = true -]]
          [[- else -]]
            [[- $isDailyRefetch = false -]]
          [[- end -]]
        [[- end -]]
      [[- end -]]
      [[- if $isDailyRefetch -]]
        [[- formatDate now "RFC3339" -]]
      [[- else -]]
        [[- .cursor.last_daily_refetch -]]
      [[- end -]]
    default: '[[ formatDate now "RFC3339" ]]'
{{else}}
- set:
    target: body.timestamp
    value: >-
      [[- if index .cursor "timestamp" -]]
        [[- .cursor.timestamp -]]
      [[- else -]]
        [[- .last_response.url.params.Get "timestamp" -]]
      [[- end -]]
    default: '[[ (now (parseDuration "-{{initial_interval}}")).Unix ]]'
{{/if}}
- set:
    # Ignored by MISP, set as a workaround to make it available in response.pagination.
    target: url.params.timestamp
    value: '[[.body.timestamp]]'
- set:
    target: body.includeDecayScore
    value: true
- set:
    target: body.order
    value: timestamp

response.split:
  target: body.response.Attribute
  ignore_empty_value: true
  keep_parent: false
response.request_body_on_pagination: true
response.pagination:
- set:
    target: body.page
    # Add 2 because the httpjson page counter is zero-based while the MISP page parameter starts at 1.
    value: '[[if (ne (len .last_response.body.response.Attribute) 0)]][[add .last_response.page 2]][[end]]'
    fail_on_template_error: true
    do_not_log_failure: true
- set:
    target: body.timestamp
    value: '[[.last_response.url.params.Get "timestamp"]]'
- set:
    target: url.params.timestamp
    value: '[[.last_response.url.params.Get "timestamp"]]'
{{#if daily_refetch}}
- set:
    # Carry the refetch marker across pagination so it survives onto the final response that the
    # cursor value template reads.
    target: url.params.daily_refetch_at
    value: '[[.last_response.url.params.Get "daily_refetch_at"]]'
{{/if}}
cursor:
  timestamp:
    value: '[[.last_event.timestamp]]'
{{#if daily_refetch}}
  last_daily_refetch:
    # Persist the refetch marker chosen by the request transform. The cursor template runs with an
    # empty .cursor, so it reads the marker back from the request's url.params instead of from cursor
    # state. See the request transform above for how the marker advances. Fall back to now if the
    # marker is missing so the cursor is never stored empty.
    value: |-
      [[- $marker := .last_response.url.params.Get "daily_refetch_at" -]]
      [[- if $marker -]]
        [[- $marker -]]
      [[- else -]]
        [[- formatDate now "RFC3339" -]]
      [[- end -]]
{{/if}}
tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#if daily_refetch}}
  - daily_refetch
{{/if}}
{{#each tags as |tag i|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
{{#if ioc_expiration_duration}}
fields_under_root: true
fields:
  _conf:
    ioc_expiration_duration: {{ioc_expiration_duration}}
{{/if}}
{{#if processors}}
processors:
{{processors}}
{{/if}}
